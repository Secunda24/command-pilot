{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CommandPilot",
  "version": "0.1.0",
  "identifier": "com.commandpilot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CommandPilot",
        "width": 1540,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": []
  }
}
